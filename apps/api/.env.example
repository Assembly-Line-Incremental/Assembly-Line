# ════════════════════════════════════════════════════════════════════
# apps/api — NestJS (Railway)
# Copy to apps/api/.env for local development.
# ════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# Same Neon PostgreSQL connection string as apps/web (shared via packages/db)
DATABASE_URL="postgresql://user:password@localhost:5432/assembly_line"

# ── Server ────────────────────────────────────────────────────────
PORT=3001
# Allowed CORS origin — URL of apps/web
WEB_URL="http://localhost:3000"

# ── Security ──────────────────────────────────────────────────────
# Shared secret for server-to-server calls from apps/web (must match apps/web INTERNAL_SECRET)
INTERNAL_SECRET=""

# ── Redis (optional) ──────────────────────────────────────────────
# When set, socket.io uses the Redis adapter for cross-instance broadcasting (Upstash recommended).
# Leave unset in local dev to use the in-memory adapter.
# REDIS_URL="redis://default:password@hostname:6379"
