# ════════════════════════════════════════════════════════════════════
# apps/web — Next.js (Vercel)
# Copy to apps/web/.env.local for local development.
# ════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/assembly_line"
NODE_ENV="development"

# ── NestJS API ────────────────────────────────────────────────────
# Server-side URL used by tRPC mutations to call apps/api
API_URL="http://127.0.0.1:3001"
# Public URL used by socket.io-client in the browser
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Shared secret for server-to-server calls (must match apps/api INTERNAL_SECRET)
INTERNAL_SECRET=""

# ── Better Auth ───────────────────────────────────────────────────
BETTER_AUTH_SECRET=""

# ── Client ────────────────────────────────────────────────────────
NEXT_PUBLIC_URL="http://localhost:3000"

# ── Sentry ────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ── Vercel (auto-injected in CI, do not set locally) ──────────────
# VERCEL_URL=