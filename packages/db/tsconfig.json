{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["src/**/*.ts", "prisma/**/*.ts"],
	"exclude": ["node_modules", "src/generated"]
}
